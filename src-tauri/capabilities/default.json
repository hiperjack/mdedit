{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-set-title",
    "core:window:allow-destroy",
    "core:window:allow-set-focus",
    "core:event:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save"
  ]
}
